# --- COMODITY DEFINITIONS ---
commodity $
  format $1,000.00

# Fixes the "3 @ $50" error for your tickets
# This declares the "empty" commodity for quantities like '3'
commodity 1,000.00 

# --- PREFERENCES ---
check-commodities


check-accounts
# --- ACCOUNT TREE ---

alias SHORT_NAME = FULL:ACCOUNT:NAME

# --- Short Aliases for Speed ---
# alias elec-sp = expenses:housing:utilities:electricity:san-pedro
# alias water-sp = expenses:housing:utilities:water:san-pedro
# alias cash = assets:cash:wallet
# alias check = assets:bank:checking

# Any account ending in ':parking' becomes 'expenses:entertainment:parking'
# alias /:parking$/ = expenses:entertainment:parking


#account assets:cash
#account expenses:food

#account Assets:Bank:Checking
#account Expenses:Food


account assets:bank:checking       ; Your main bank account
#account assets:bank:debit-card     ; Usually maps to the same checking account
account expenses:housing:rent      ; Your monthly rent payment
account expenses:car:fuel          ; Gasoline/Charging
account expenses:car:insurance     ; Monthly or yearly premium
account expenses:car:maintenance   ; Oil changes, tires, etc.
account expenses:car:verificacion
account expenses:car:tenencia

# 2026-04-15 Secretaria de Finanzas | Tenencia 2026 - Plate ABC-123
#     expenses:transport:car:tenencia     $650.00
#     assets:bank:checking

account expenses:household:fortnight       ; specific 15-day cycle of settling all your major recurring obligations—rent, utilities, and shared household costs—in one go.


# --- Income (Money coming in) ---
account income:rent                  ; Money you receive from your property


# --- Expenses (Money you spend) ---
account expenses:education:japanese  ; Your classes
account expenses:education:daughter  ; Daughter's English classes
account expenses:housing:maintenance  ; Department maintenance fees
account expenses:education:daughter:english

# --- Liabilities (Money passing through) ---
account liabilities:family:bil-insurance  ; Money your Brother-in-law owes/pays you


account expenses:housing:maintenance:san-pedro
account expenses:housing:maintenance:puerta-toreo

account expenses:entertainment:concert
account expenses:entertainment:parking
account expenses:entertainment:fees


account expenses:health:medical  ; (For doctor visits, consultations, and lab tests)
account expenses:health:pharmacy  ; (For medicines, prescriptions, and first-aid supplies)
account expenses:health:insurance  ; (If you pay a monthly premium or copay)


# --- Utilities Hierarchy ---
account expenses:housing:utilities:electricity:san-pedro
account expenses:housing:utilities:electricity:puerta-toreo
account expenses:housing:utilities:water:san-pedro
account expenses:housing:utilities:water:puerta-toreo
account expenses:housing:utilities:gas:san-pedro
account expenses:housing:utilities:gas:puerta-toreo
account expenses:housing:utilities:internet
account expenses:housing:taxes:predial:san-pedro
account expenses:housing:taxes:predial:puerta-toreo

